# ===== REQUIRED =====

# Single catch-all: points at your Quickback origin. API + Account + CMS URLs
# are all derived from this unless you override them explicitly below.
# Local: http://localhost:3000 or http://localhost:8787
VITE_QUICKBACK_URL=http://localhost:3000

# Explicit overrides (optional — only needed for split-subdomain setups)
# VITE_QUICKBACK_API_URL=https://api.example.com
# VITE_QUICKBACK_ACCOUNT_URL=https://auth.example.com
# VITE_QUICKBACK_CMS_URL=https://cms.example.com

# This Account UI's URL
# Local: http://localhost:5173
VITE_ACCOUNT_APP_URL=http://localhost:5173

# ===== AUTH ROUTE MODE =====

# Route convention: 'better-auth' (default) or 'quickback'
#   better-auth → /api/auth/*
#   quickback   → /auth/v1/*, /api/v1/*, /storage/v1/*
VITE_AUTH_ROUTE=better-auth

# ===== APP IDENTITY =====

VITE_APP_NAME=My App
VITE_APP_TAGLINE=Welcome to My App
VITE_APP_DESCRIPTION=Account management for My App
VITE_COMPANY_NAME=My Company Inc.
VITE_COMPANY_ADDRESS=

# ===== URLS =====

# Main application URL (users redirect here after login)
VITE_QUICKBACK_APP_URL=http://localhost:3000

# Organization URL pattern ({slug} is replaced with org slug)
VITE_TENANT_URL_PATTERN=/organizations/{slug}

# Footer links
VITE_SUPPORT_URL=
VITE_PRIVACY_URL=
VITE_TERMS_URL=

# ===== EMAIL =====

VITE_EMAIL_FROM=noreply@example.com
VITE_EMAIL_REPLY_TO=support@example.com
VITE_SUPPORT_EMAIL=support@example.com
VITE_EMAIL_REGION=us-east-1

# ===== BRANDING =====

VITE_THEME_COLOR=#1e293b

# ===== FEATURE FLAGS =====

ENABLE_SIGNUP=true
ENABLE_EMAIL_VERIFICATION=true
ENABLE_PASSKEY=true
ENABLE_EMAIL_OTP=true
ENABLE_PASSWORD=false
ENABLE_ORGANIZATIONS=true
ENABLE_ADMIN=true
VITE_ENABLE_FILE_UPLOADS=false

# Disable email deliverability checks in development
DISABLE_EMAIL_STATUS_CHECK=true

# ===== STRIPE (optional) =====

# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
